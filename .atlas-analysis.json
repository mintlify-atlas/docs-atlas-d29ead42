  "keyFeatures": [
    "Anonymous URL creation with 8-hour TTL",
    "Authenticated user accounts with permanent links",
    "JWT-based authentication with Spring Security",
    "Real-time redirect latency tracking using Welford's algorithm",
    "Automated cleanup of expired URLs with @Scheduled tasks",
    "URL synchronization from anonymous to authenticated mode",
    "HTTP 410 Gone responses for expired links",
    "PostgreSQL database with AWS RDS support",
    "Containerized deployment with Docker and AWS ECS Fargate",
    "Infrastructure as Code with Terraform modules",
    "Application Load Balancer with HTTPS support",
    "React SPA with TypeScript and shadcn/ui components"
  ],
